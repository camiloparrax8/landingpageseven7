{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/index.html",
      "destination": "/",
      "statusCode": 308,
      "regex": "^(?!/_next)/index\\.html(?:/)?$"
    },
    {
      "source": "/services.html",
      "destination": "/services",
      "statusCode": 308,
      "regex": "^(?!/_next)/services\\.html(?:/)?$"
    },
    {
      "source": "/consultoria-tecnologica.html",
      "destination": "/consultoria-tecnologica",
      "statusCode": 308,
      "regex": "^(?!/_next)/consultoria-tecnologica\\.html(?:/)?$"
    },
    {
      "source": "/ia.html",
      "destination": "/ia",
      "statusCode": 308,
      "regex": "^(?!/_next)/ia\\.html(?:/)?$"
    },
    {
      "source": "/desarrollo-web.html",
      "destination": "/desarrollo-web",
      "statusCode": 308,
      "regex": "^(?!/_next)/desarrollo-web\\.html(?:/)?$"
    },
    {
      "source": "/aplicaciones-moviles.html",
      "destination": "/aplicaciones-moviles",
