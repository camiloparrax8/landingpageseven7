    },
    {
      "page": "/[locale]/ia",
      "regex": "^/([^/]+?)/ia(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/ia(?:/)?$"
    },
    {
      "page": "/[locale]/services",
      "regex": "^/([^/]+?)/services(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/services(?:/)?$"
    },
    {
      "page": "/[locale]/software-medida",
      "regex": "^/([^/]+?)/software\\-medida(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/software\\-medida(?:/)?$"
    },
    {
      "page": "/[locale]/transformacion-digital",
      "regex": "^/([^/]+?)/transformacion\\-digital(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
