    },
    {
      "source": "/transformacion-digital.html",
      "destination": "/transformacion-digital",
      "statusCode": 308,
      "regex": "^(?!/_next)/transformacion-digital\\.html(?:/)?$"
    },
    {
      "source": "/contacto.html",
      "destination": "/contacto",
      "statusCode": 308,
      "regex": "^(?!/_next)/contacto\\.html(?:/)?$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/[locale]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[locale]/aplicaciones-moviles",
      "regex": "^/([^/]+?)/aplicaciones\\-moviles(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
