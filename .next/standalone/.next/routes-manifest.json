      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/consultoria\\-tecnologica(?:/)?$"
    },
    {
      "page": "/[locale]/contacto",
      "regex": "^/([^/]+?)/contacto(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/contacto(?:/)?$"
    },
    {
      "page": "/[locale]/desarrollo-web",
