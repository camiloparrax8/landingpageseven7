{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/aplicaciones-moviles/layout,_N_T_/[locale]/aplicaciones-moviles/page,_N_T_/en/aplicaciones-moviles"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/aplicaciones-moviles/__PAGE__",
    "/$d$locale/aplicaciones-moviles",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}