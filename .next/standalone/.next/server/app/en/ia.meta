{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/ia/layout,_N_T_/[locale]/ia/page,_N_T_/en/ia"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/ia/__PAGE__",
    "/$d$locale/ia",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}