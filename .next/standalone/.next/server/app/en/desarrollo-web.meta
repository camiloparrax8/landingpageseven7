{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/desarrollo-web/layout,_N_T_/[locale]/desarrollo-web/page,_N_T_/en/desarrollo-web"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/desarrollo-web/__PAGE__",
    "/$d$locale/desarrollo-web",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}