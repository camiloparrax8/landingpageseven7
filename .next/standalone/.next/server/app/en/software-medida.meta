{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/software-medida/layout,_N_T_/[locale]/software-medida/page,_N_T_/en/software-medida"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/software-medida/__PAGE__",
    "/$d$locale/software-medida",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}