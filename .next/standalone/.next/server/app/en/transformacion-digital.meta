{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/transformacion-digital/layout,_N_T_/[locale]/transformacion-digital/page,_N_T_/en/transformacion-digital"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/transformacion-digital/__PAGE__",
    "/$d$locale/transformacion-digital",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}